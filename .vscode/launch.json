{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to west debugserver (OpenOCD)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/zephyr/build/zephyr/zephyr.elf",
      "cwd": "${workspaceFolder}/zephyr",
      "MIMode": "gdb",
      "miDebuggerPath": "/opt/st/stm32cubeclt_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
      "miDebuggerServerAddress": "localhost:3333",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ],
      "stopAtEntry": false
    }
  ]
}
